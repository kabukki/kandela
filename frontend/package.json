		"@tailwindcss/vite": "^4.1.16",
		"@types/d3-force": "^3.0.10",
		"@types/d3-interpolate": "^3.0.4",
		"@types/react": "^19.1.10",
		"@types/react-dom": "^19.1.7",
		"@vitejs/plugin-react": "^5.0.0",
		"globals": "^16.3.0",
		"tailwindcss": "^4.1.16",
